APP_NAME=fastapi-counter
APP_ENV=dev
LOG_LEVEL=INFO
UPLOADS_DIR=app/storage/uploads
UPLOADS_MAX_SIZE_MB=10
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+|192\.168\.\d+\.\d+)(:\d+)?$
GENAI_API_KEY=
GENAI_BASE_URL=https://api.gen-api.ru/api/v1
GENAI_DEFAULT_LLM_NETWORK=gemini-3-flash
GENAI_DEFAULT_IMAGE_NETWORK=flux-2
GENAI_IMAGES_DIR=app/storage/genai
PRESENTATIONS_DIR=app/storage/presentations
PRESENTATION_MIN_SLIDES=5
PRESENTATION_MAX_SLIDES=20
